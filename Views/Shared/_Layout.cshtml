<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Arkived</title>
    <!-- Specify exact version to avoid Unpkg/CDN 302 redirects -->
    <script src="https://cdn.tailwindcss.com/3.4.3"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {}
            }
        }
    </script>
    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; }
        .glass-card {
            background: rgba(15, 15, 15, 0.7);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            transition: border-color 220ms ease, background-color 220ms ease;
        }
        .glass-card:hover { border-color: rgba(255, 255, 255, 0.18); }
        body::before {
            content: "";
            position: fixed;
            inset: 0;
            pointer-events: none;
            background:
                radial-gradient(700px 350px at 10% -10%, rgba(255, 255, 255, 0.08), transparent 60%),
                radial-gradient(900px 450px at 100% 0%, rgba(96, 165, 250, 0.10), transparent 60%);
            z-index: -1;
        }
    </style>
</head>
<body class="bg-zinc-950 text-zinc-100 antialiased selection:bg-white selection:text-black">
    <header class="sticky top-0 z-50 glass-card">
        <div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
            <a href="/" class="text-xl font-bold tracking-tight hover:text-zinc-300 transition-colors">Arkived.</a>
            <nav class="space-x-6 text-sm font-medium">
                <a href="/Blog" class="text-zinc-400 hover:text-white transition-colors">Posts</a>
            </nav>
        </div>
    </header>

    <main class="min-h-screen py-10 px-6 max-w-6xl mx-auto flex flex-col">
        @RenderBody()
    </main>

    <footer class="mt-auto py-8 text-center text-sm text-zinc-500 glass-card border-none border-t border-white/10">
        <div class="flex items-center justify-center gap-4">
            <span>&copy; 2026 Arkived.</span>
            <a href="https://www.facebook.com/arkivedsolutions" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="text-zinc-500 hover:text-blue-500 transition-colors">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd"></path>
                </svg>
            </a>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
